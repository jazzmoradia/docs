{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "OmniScape",
  "description": "Deterministic procedural settlement generation for Unreal Engine. One actor, one Control Center, your art.",
  "colors": {
    "primary": "#A8742A",
    "light": "#8A5E1F",
    "dark": "#CCA060"
  },
  "appearance": {
    "default": "light",
    "strict": true
  },
  "fonts": {
    "heading": {
      "family": "Outfit",
      "weight": 600
    },
    "body": {
      "family": "Outfit",
      "weight": 400
    }
  },
  "icons": {
    "library": "lucide"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "favicon": "/favicon.svg",
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "one-dark-pro"
      }
    }
  },
  "background": {
    "decoration": "grid",
    "color": {
      "dark": "#08090A",
      "light": "#F3F1EA"
    }
  },
  "banner": {
    "content": "OmniScape 3.0 is on the way \u2014 Atlas real-world import, semantic zones, and a fully rebuilt v3 generator. [See what's new](/help/changelog)",
    "dismissible": true,
    "color": {
      "light": "#5A3E18",
      "dark": "#5A3E18"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Get it on Fab",
          "icon": "store",
          "href": "https://fab.com/s/4aeff49faf04"
        },
        {
          "anchor": "Watch the demo",
          "icon": "play",
          "href": "https://youtu.be/xFo9JeM7dgc"
        },
        {
          "anchor": "Support thread",
          "icon": "life-buoy",
          "href": "https://gist.github.com/jazzmoradia/6c4383fb51914f9bf083ccd472ee6b12"
        },
        {
          "anchor": "Discord",
          "icon": "message-circle",
          "href": "https://discord.gg/UjXbjW6gUH"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Overview",
        "icon": "compass",
        "groups": [
          {
            "group": "Discover OmniScape",
            "pages": [
              "overview/introduction",
              "overview/what-you-get",
              "overview/compatibility"
            ]
          }
        ]
      },
      {
        "tab": "Get started",
        "icon": "rocket",
        "groups": [
          {
            "group": "First steps",
            "pages": [
              "get-started/quickstart",
              "get-started/first-settlement",
              "get-started/save-to-level"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "The Control Center",
            "pages": [
              "guides/control-center",
              "guides/layout",
              "guides/build",
              "guides/structure",
              "guides/ambient"
            ]
          },
          {
            "group": "Creative direction",
            "pages": [
              "guides/creative-direction",
              "guides/presets",
              "guides/atlas"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "guides/volumes-and-anchors",
              "guides/blueprint-and-runtime"
            ]
          }
        ]
      },
      {
        "tab": "Help",
        "icon": "life-buoy",
        "groups": [
          {
            "group": "Support",
            "pages": [
              "help/troubleshooting",
              "help/faq",
              "help/community",
              "help/changelog"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Demo",
        "icon": "play",
        "href": "https://youtu.be/xFo9JeM7dgc"
      },
      {
        "type": "discord",
        "href": "https://discord.gg/UjXbjW6gUH"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get OmniScape",
      "href": "https://fab.com/s/4aeff49faf04"
    }
  },
  "search": {
    "prompt": "Search the settlement\u2026"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/UjXbjW6gUH",
      "youtube": "https://youtu.be/xFo9JeM7dgc"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "Overview", "href": "/overview/introduction" },
          { "label": "Quick start", "href": "/get-started/quickstart" },
          { "label": "Changelog", "href": "/help/changelog" },
          { "label": "Get it on Fab", "href": "https://fab.com/s/4aeff49faf04" }
        ]
      },
      {
        "header": "Learn",
        "items": [
          { "label": "Control Center", "href": "/guides/control-center" },
          { "label": "Creative direction", "href": "/guides/creative-direction" },
          { "label": "Presets", "href": "/guides/presets" },
          { "label": "Atlas", "href": "/guides/atlas" }
        ]
      },
      {
        "header": "Support",
        "items": [
          { "label": "Troubleshooting", "href": "/help/troubleshooting" },
          { "label": "FAQ", "href": "/help/faq" },
          { "label": "Support thread", "href": "https://gist.github.com/jazzmoradia/6c4383fb51914f9bf083ccd472ee6b12" },
          { "label": "Discord", "href": "https://discord.gg/UjXbjW6gUH" }
        ]
      }
    ]
  }
}
