  "keyFeatures": [
    "One actor, one Control Center — no PCG graph required",
    "Deterministic generation: same seed + same settings = same layout on every machine",
    "Bring-your-own-art (BYOA) — assign any meshes or Blueprints across Large, Medium, and Small building tiers",
    "Five layout patterns: Radial, Voronoi, Perlin, Axial/Grid, Organic",
    "Roads with terrain-following elevation modes (Follow, Contour, Level)",
    "Full and partial wall system with gates, pillars, and shape styles",
    "Flora, fauna, and ambient audio layers in the Ambient tab",
    "Volumes and anchors for precise spatial control",
    "Twelve archetype presets (fortress, urban, rural, hills, landmark) as starting points",
    "Atlas wizard for real-world layout reference from OpenStreetMap",
    "Blueprint and runtime API for in-game generation",
    "PCG Hand-off for exporting layout data to external PCG graphs"
  ],
  "publicApiSurface": [
    "GenerateSettlement (Blueprint action)",
    "ClearSettlement (Blueprint action)",
    "CanGenerateSettlement (Blueprint preflight check)",
    "GetLastGenerationResult (Blueprint query)",
    "GetLastLayoutValidation (Blueprint query)",
    "LoadProfileAndGenerate (Blueprint action)",
    "CancelGeneration (Blueprint action)",
    "RebuildWallsOnly (Blueprint action)",
    "OnSettlementGenerated (Blueprint event)",
    "OnSettlementGenerationCompleted (Blueprint event with FOmniScapeGenerationResult)",
    "OnSettlementCleared (Blueprint event)",
    "OnGenerationProgress (Blueprint event, 0–1 during time-sliced spawn)",
    "OnBuildingSpawned (Blueprint hook, Large/Medium/Small/Sprawl Blueprint buildings)",
    "GenerationSeed (UProperty, integer)",
    "UOmniScapePCGDataComponent (PCG Hand-off data component)",
    "RuntimeProfile (data asset for LoadProfileAndGenerate)"
  ]
}
